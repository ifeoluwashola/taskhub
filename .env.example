# Docker image tag to deploy
IMAGE_VERSION=v3

# MongoDB
MONGO_ROOT_USER=your_mongo_admin_user
MONGO_ROOT_PASSWORD=your_mongo_admin_password
MONGO_DB_NAME=taskhub
MONGO_PORT=27017

# Backend
BACKEND_PORT=3001

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://your-ec2-public-ip:3001

# App
NODE_ENV=production

# JWT / Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# CORS — must match wherever the frontend is actually served from
CORS_ORIGIN=http://your-ec2-public-ip:3000